# Copy to `.env` and fill in. The BudgetBug example's setup hook reads
# these to log into the running BudgetBug dev server before capture.
#
# Defaults assume `pnpm dev` in the BudgetBug repo with its standard demo
# user. Override BUDGETBUG_BASE_URL to point at staging or production
# instead.

BUDGETBUG_BASE_URL=http://localhost:5173
BUDGETBUG_DEMO_EMAIL=demo@budgetbug.live
BUDGETBUG_DEMO_PASSWORD=
