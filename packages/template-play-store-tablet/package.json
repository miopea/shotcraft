{
  "name": "@shotcraft/template-play-store-tablet",
  "version": "1.0.2",
  "description": "Shotcraft template — Google Play 7\" tablet screenshot composite. 1920×1200 landscape, two-pane layout, Android tablet frame.",
  "keywords": [
    "shotcraft",
    "shotcraft-template",
    "play-store",
    "tablet",
    "screenshot"
  ],
  "homepage": "https://github.com/miopea/shotcraft",
  "repository": {
    "type": "git",
    "url": "https://github.com/miopea/shotcraft.git",
    "directory": "packages/template-play-store-tablet"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wrapper.html",
    "wrapper.css",
    "frames",
    "samples",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "shotcraft": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "playwright": "^1.49.0",
    "shotcraft": "workspace:*",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
