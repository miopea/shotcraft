{
  "name": "@shotcraft/template-desktop-hero",
  "version": "1.1.0",
  "description": "Shotcraft template — Desktop hero composite. 1920×1080 landscape, browser-chrome framed, dark + light variants. Good for README heroes, landing pages, blog posts, OG images.",
  "keywords": [
    "shotcraft",
    "shotcraft-template",
    "desktop",
    "hero",
    "readme",
    "landing"
  ],
  "homepage": "https://shotcraft.dev",
  "repository": {
    "type": "git",
    "url": "https://github.com/miopea/shotcraft.git",
    "directory": "packages/template-desktop-hero"
  },
  "license": "MIT",
  "type": "module",
  "main": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js",
      "default": "./dist/index.js"
    }
  },
  "files": [
    "dist",
    "wrapper.html",
    "wrapper.css",
    "samples",
    "README.md"
  ],
  "scripts": {
    "build": "tsup",
    "test": "vitest run --passWithNoTests",
    "typecheck": "tsc --noEmit",
    "dev": "tsup --watch"
  },
  "peerDependencies": {
    "shotcraft": "workspace:*"
  },
  "devDependencies": {
    "@types/node": "^22.7.0",
    "playwright": "^1.49.0",
    "shotcraft": "workspace:*",
    "tsup": "^8.2.4",
    "typescript": "^5.6.2",
    "vitest": "^2.1.1"
  },
  "engines": {
    "node": ">=20"
  },
  "publishConfig": {
    "access": "public",
    "provenance": true
  }
}
