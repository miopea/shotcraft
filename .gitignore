# Dependencies
node_modules/
.pnpm-store/

# Build artifacts
dist/
build/
*.tsbuildinfo

# Test artifacts
coverage/

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Env / secrets
.env
.env.local
.env.*.local

# Render outputs (examples generate these). Curated copies that ship in
# the repo (the README hero, OG card, etc.) live under `assets/`.
examples/*/screenshots/

# Docs site build (Astro Starlight default)
docs/.astro/
docs/dist/
# Sample PNGs are copied in by scripts/copy-samples.mjs at build time.
# Source of truth lives in `packages/template-*/samples/`.
docs/public/samples/

# @shotcraft/web build artifacts + same sample-copy pattern as docs/.
packages/web/dist/
packages/web/server/dist/
packages/web/client/public/samples/

# Changesets — `.changeset/*.md` files ARE the source of truth (they describe
# pending version bumps) and must be committed. Nothing to ignore here.

# Claude Code / MCP — operator-machine state (commands, skills, MCP servers,
# local settings). `.claude/plans/` is the only subdir we track, since plans
# describe the project itself.
.claude/commands/
.claude/skills/
.claude/settings.local.json
.mcp.json
