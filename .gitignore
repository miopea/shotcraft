# Dependencies
node_modules/
.pnpm-store/

# Build artifacts
dist/
build/
*.tsbuildinfo

# Test artifacts
coverage/

# Editor / OS
.DS_Store
.idea/
.vscode/*
!.vscode/extensions.json
*.swp
*.swo

# Logs
*.log
npm-debug.log*
yarn-debug.log*
pnpm-debug.log*

# Env / secrets
.env
.env.local
.env.*.local

# Render outputs (examples generate these). Curated copies that ship in
# the repo (the README hero, OG card, etc.) live under `assets/`.
examples/*/screenshots/

# @shotcraft/web build artifacts + sample copies
packages/web/dist/
packages/web/server/dist/
packages/web/client/public/samples/

# Defensive — defunct Astro Starlight cache that regenerates if anyone
# scaffolds a fresh docs site under this path.
docs/.astro/

# Changesets — `.changeset/*.md` files ARE the source of truth (they describe
# pending version bumps) and must be committed. Nothing to ignore here.

# Claude Code / MCP — most subdirs are operator-machine state, but
# `.claude/commands/` and `.claude/plans/` are project-shared:
# slash commands like `/deploy` describe how to operate this repo,
# plans capture in-flight design.
.claude/skills/
.claude/settings.local.json
.mcp.json
